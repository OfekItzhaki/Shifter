# Staging environment example for running a second Shifter stack on the same VPS.
# Copy to /opt/shifter-staging/infra/compose/.env and replace every secret/domain.

COMPOSE_PROJECT_NAME=shifter-staging
SHIFTER_DEPLOYMENT_MODE=saas

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=15432
POSTGRES_DB=shifter_staging
POSTGRES_USER=shifter_staging
POSTGRES_PASSWORD=change_me_staging_postgres

# Redis
REDIS_HOST=redis
REDIS_PORT=16379
REDIS_PASSWORD=change_me_staging_redis

# API
API_PORT=15000
JWT_SECRET=change_me_staging_jwt_secret_min_32_chars_long
JWT_ISSUER=shifter-staging-api
JWT_AUDIENCE=shifter-staging-web
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# Solver
SOLVER_PORT=18000
SOLVER_TIMEOUT_SECONDS=60
SOLVE_TIMEOUT_SECONDS=120

# Frontend
WEB_PORT=13000
NEXT_PUBLIC_API_URL=https://staging-api.example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
NEXT_PUBLIC_CRISP_WEBSITE_ID=
NEXT_PUBLIC_LEGAL_EMAIL=support@ofeklabs.com

# Sentry / analytics
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Local MinIO
MINIO_ROOT_USER=staging_minio
MINIO_ROOT_PASSWORD=change_me_staging_minio
MINIO_PORT=19000
MINIO_CONSOLE_PORT=19001

# S3-compatible storage. Prefer a separate staging bucket if enabled.
STORAGE_S3_BUCKET_NAME=
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_SERVICE_URL=
STORAGE_S3_PUBLIC_BASE_URL=
STORAGE_S3_FORCE_PATH_STYLE=false

# Optional AI. Usually disabled in staging unless explicitly testing AI features.
AI_API_KEY=
AI_MODEL=gpt-4o

# Background jobs. Keep disabled until staging behavior is intentionally tested.
AUTO_SCHEDULER_ENABLED=false

# App URLs
APP_FRONTEND_BASE_URL=https://staging.example.com
APP_API_BASE_URL=https://staging-api.example.com

# Email / messaging. Use sandbox credentials or leave empty.
FEEDBACK_DEVELOPER_EMAIL=ofeklabs@outlook.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@staging.example.com
RESEND_FROM_NAME=Shifter Staging

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@staging.example.com

# Billing. Use LemonSqueezy test values only.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_DEFAULT_VARIANT_ID=
LEMONSQUEEZY_TEST_VARIANT_ID=

# Seq
SEQ_ADMIN_PASSWORD=change_me_staging_seq_admin
SEQ_UI_USERNAME=admin
SEQ_UI_PASSWORD_HASH=$$2a$$14$$replace_with_real_bcrypt_hash

# Health alerting. Usually disabled for staging or routed to a low-noise channel.
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=
HEALTH_CHECK_INTERVAL_SECONDS=300
HEALTH_CHECK_ALERT_COOLDOWN_SECONDS=3600
