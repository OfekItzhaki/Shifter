# Customer-hosted Shifter install.
# Copy this file to infra/compose/.env and replace every change_me_* value.

SHIFTER_DEPLOYMENT_MODE=customer-hosted
COMPOSE_PROJECT_NAME=shifter
SHIFTER_LICENSEE=change_me_customer_legal_name
SHIFTER_LICENSE_KEY=change_me_customer_license_key_min_24_chars

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=shifter
POSTGRES_USER=shifter
POSTGRES_PASSWORD=change_me_customer_postgres

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_customer_redis

# API
API_PORT=5000
JWT_SECRET=change_me_customer_jwt_secret_min_32_chars_long
JWT_ISSUER=shifter-customer-api
JWT_AUDIENCE=shifter-customer-web
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7
FIELD_ENCRYPTION_KEY=change_me_customer_field_encryption_key_min_32_chars_long

# Solver
SOLVER_PORT=8000
SOLVER_TIMEOUT_SECONDS=60
SOLVE_TIMEOUT_SECONDS=120

# Frontend
WEB_PORT=3000
NEXT_PUBLIC_API_URL=https://api-shifter.customer.example
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
NEXT_PUBLIC_CRISP_WEBSITE_ID=
NEXT_PUBLIC_LEGAL_EMAIL=it-support@customer.example
NEXT_PUBLIC_APP_VERSION=customer-1.0.0

# Disable external telemetry by default for customer-hosted installs.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Local MinIO
MINIO_ROOT_USER=shifter_minio
MINIO_ROOT_PASSWORD=change_me_customer_minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# S3-compatible storage.
# For bundled MinIO, set ServiceUrl to http://minio:9000 and ForcePathStyle=true.
# For customer S3/R2/MinIO, use the customer's bucket and credentials.
STORAGE_S3_BUCKET_NAME=shifter-uploads
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=shifter_minio
STORAGE_S3_SECRET_KEY=change_me_customer_minio
STORAGE_S3_SERVICE_URL=http://minio:9000
STORAGE_S3_PUBLIC_BASE_URL=
STORAGE_S3_FORCE_PATH_STYLE=true

# AI.
# Leave all empty to disable AI.
# For hosted/customer cloud AI: set AI_API_KEY, AI_BASE_URL, and AI_MODEL.
# For no-export local AI: set AI_BASE_URL and AI_MODEL; AI_API_KEY may stay empty.
AI_NO_EXPORT_REQUIRED=false
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# Background jobs.
AUTO_SCHEDULER_ENABLED=false

# Manual self-service defaults for newly enabled self-service groups.
SELF_SERVICE_DEFAULT_MIN_SHIFTS_PER_CYCLE=0
SELF_SERVICE_DEFAULT_MAX_SHIFTS_PER_CYCLE=7
SELF_SERVICE_DEFAULT_REQUEST_WINDOW_OPEN_OFFSET_HOURS=168
SELF_SERVICE_DEFAULT_REQUEST_WINDOW_CLOSE_OFFSET_HOURS=24
SELF_SERVICE_DEFAULT_CANCELLATION_CUTOFF_HOURS=24
SELF_SERVICE_DEFAULT_MAX_ABSENCES_PER_CYCLE=3
SELF_SERVICE_DEFAULT_MAX_LATE_CANCELLATIONS_PER_CYCLE=2
SELF_SERVICE_DEFAULT_LATE_CANCELLATION_WINDOW_HOURS=24
SELF_SERVICE_DEFAULT_WAITLIST_OFFER_MINUTES=60
SELF_SERVICE_DEFAULT_CYCLE_DURATION_DAYS=7
SELF_SERVICE_DEFAULT_ALLOW_MEMBER_SHIFT_CLAIMS=true
SELF_SERVICE_DEFAULT_ALLOW_WAITLIST=true
SELF_SERVICE_DEFAULT_ALLOW_SHIFT_CHANGE_REQUESTS=true
SELF_SERVICE_DEFAULT_ALLOW_ABSENCE_REPORTS=true
SELF_SERVICE_DEFAULT_ALLOW_SHIFT_SWAPS=true

# App URLs
APP_FRONTEND_BASE_URL=https://shifter.customer.example
APP_API_BASE_URL=https://api-shifter.customer.example

# Email via Resend. Leave empty if the customer has not approved external email.
FEEDBACK_DEVELOPER_EMAIL=it-support@customer.example
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@customer.example
RESEND_FROM_NAME=Shifter

# WhatsApp via Twilio. Leave empty unless approved.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Billing. Usually disabled for customer-hosted enterprise installs.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_DEFAULT_VARIANT_ID=
LEMONSQUEEZY_TEST_VARIANT_ID=

# Seq
SEQ_ADMIN_PASSWORD=change_me_customer_seq_admin
SEQ_UI_USERNAME=admin
SEQ_UI_PASSWORD_HASH=$$2a$$14$$replace_with_real_bcrypt_hash

# Health alerts. Leave empty until customer-owned alerting is configured.
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=
HEALTH_CHECK_INTERVAL_SECONDS=300
HEALTH_CHECK_ALERT_COOLDOWN_SECONDS=3600
