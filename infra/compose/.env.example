# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=jobuler
POSTGRES_USER=jobuler
POSTGRES_PASSWORD=changeme_local

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── API ──────────────────────────────────────────────────────
API_PORT=5000
JWT_SECRET=changeme_jwt_secret_min_32_chars_long
JWT_ISSUER=jobuler-api
JWT_AUDIENCE=jobuler-web
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ─── Solver ───────────────────────────────────────────────────
SOLVER_PORT=8000
SOLVER_TIMEOUT_SECONDS=60

# ─── Frontend ─────────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here
NEXT_PUBLIC_CRISP_WEBSITE_ID=
NEXT_PUBLIC_LEGAL_EMAIL=support@ofeklabs.com

# ─── Sentry (Error Tracking) ──────────────────────────────────────────────────
# Get your DSN from sentry.io → Project Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=

# ─── PostHog (Analytics) ───────────────────────────────────────────────────────
# Get your project API key from posthog.com → Project Settings
# Leave empty to disable analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── MinIO (S3-compatible local storage) ──────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── S3-compatible file storage ───────────────────────────────────────────────
# For local dev with MinIO: set BucketName + use MinIO credentials below
# For AWS S3: set BucketName, Region, AccessKey, SecretKey — leave ServiceUrl empty
# For Cloudflare R2: set ServiceUrl to your R2 endpoint
# Leave BucketName empty to use local disk storage (wwwroot/uploads)
STORAGE_S3_BUCKET_NAME=
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_SERVICE_URL=          # e.g. http://minio:9000 for MinIO, empty for AWS
STORAGE_S3_PUBLIC_BASE_URL=      # e.g. https://cdn.example.com or http://localhost:9000/shifter-uploads
STORAGE_S3_FORCE_PATH_STYLE=false  # set true for MinIO

# ─── AI (optional) ────────────────────────────────────────────────────────────
# Leave empty to disable AI features — app runs fine without it
AI_API_KEY=
AI_MODEL=gpt-4o

# ─── Auto-scheduler ───────────────────────────────────────────────────────────
# Set to true to enable automatic schedule generation when coverage gaps are detected
# Runs every 6 hours. Disable in dev if you don't want background solver runs.
AUTO_SCHEDULER_ENABLED=false

# ─── App URLs ─────────────────────────────────────────────────────────────────
APP_FRONTEND_BASE_URL=http://localhost:3000
APP_API_BASE_URL=http://localhost:5000

# ─── SendGrid (Email) ──────────────────────────────────────────────────────────
# Leave empty to use no-op (logs only, no real emails sent)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@shifter.app
SENDGRID_FROM_NAME=Shifter

# ─── Twilio (WhatsApp) ────────────────────────────────────────────────────────
# Leave empty to use no-op (logs only, no real WhatsApp messages sent)
# Use the Twilio sandbox number for testing: whatsapp:+14155238886
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate keys with: npx web-push generate-vapid-keys
# Leave empty to disable push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@shifter.app

# ─── LemonSqueezy (Billing) ───────────────────────────────────────────────────
# Get credentials from https://app.lemonsqueezy.com/settings/api
# All values are required for billing to work. If missing, billing endpoints will be unavailable but the app will still start.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_DEFAULT_VARIANT_ID=
LEMONSQUEEZY_TEST_VARIANT_ID=

# ─── Seq (Centralized Logging) ────────────────────────────────────────────────
# Initial admin password for the Seq web UI (set on first run)
SEQ_ADMIN_PASSWORD=changeme_seq_admin
# Caddy basic auth credentials for external Seq UI access
# Username for HTTP Basic Auth
SEQ_UI_USERNAME=admin
# Bcrypt hash of the password — generate with: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password-here'
SEQ_UI_PASSWORD_HASH=$2a$14$changeme_replace_with_real_bcrypt_hash

# ─── Health Check Alerts (Pushover) ───────────────────────────────────────────
# Get credentials from https://pushover.net — create an application to get the token
# Leave empty to disable push notifications (health monitor still runs and logs)
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=
# Polling interval in seconds (minimum 30, default 300)
HEALTH_CHECK_INTERVAL_SECONDS=300
# Cooldown between duplicate alerts for the same service in seconds (default 3600)
HEALTH_CHECK_ALERT_COOLDOWN_SECONDS=3600
